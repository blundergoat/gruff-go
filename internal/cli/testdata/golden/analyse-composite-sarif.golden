{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "gruff-go",
          "semanticVersion": "0.1.0-dev",
          "rules": [
            {
              "id": "complexity.cyclomatic",
              "name": "Cyclomatic complexity",
              "shortDescription": {
                "text": "Cyclomatic complexity"
              },
              "fullDescription": {
                "text": "Flags Go functions whose branch count exceeds the default cyclomatic threshold."
              },
              "help": {
                "text": "Split independent decisions or move branches into named helpers."
              },
              "properties": {
                "pillar": "complexity",
                "defaultSeverity": "medium",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "thresholds": {
                  "maxComplexity": 2
                }
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            },
            {
              "id": "complexity.nesting-depth",
              "name": "Nesting depth",
              "shortDescription": {
                "text": "Nesting depth"
              },
              "fullDescription": {
                "text": "Flags functions whose maximum control-flow nesting depth exceeds the configured threshold. Function literals reset the count."
              },
              "help": {
                "text": "Extract nested branches into named helpers or return early on guard conditions."
              },
              "properties": {
                "pillar": "complexity",
                "defaultSeverity": "medium",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "opt-in"
                ],
                "thresholds": {
                  "maxDepth": 4
                }
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            },
            {
              "id": "dead-code.empty-block",
              "name": "Empty control-flow block",
              "shortDescription": {
                "text": "Empty control-flow block"
              },
              "fullDescription": {
                "text": "Flags empty control-flow blocks that usually indicate unfinished or unnecessary code."
              },
              "help": {
                "text": "Remove the empty block or add the intended implementation."
              },
              "properties": {
                "pillar": "dead-code",
                "defaultSeverity": "low",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "opt-in"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "design.god-function",
              "name": "God function",
              "shortDescription": {
                "text": "God function"
              },
              "fullDescription": {
                "text": "Flags functions that already have both size and complexity findings, prioritising routines that need structural decomposition."
              },
              "help": {
                "text": "Split the function around cohesive responsibilities, then re-run the size and complexity rules to confirm both signals cleared."
              },
              "properties": {
                "pillar": "design",
                "secondaryPillars": [
                  "size",
                  "complexity"
                ],
                "defaultSeverity": "low",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "composite",
                  "opt-in"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "design.hotspot-file",
              "name": "Hotspot file",
              "shortDescription": {
                "text": "Hotspot file"
              },
              "fullDescription": {
                "text": "Flags files with findings across multiple quality pillars, highlighting cross-cutting maintenance hotspots."
              },
              "help": {
                "text": "Triage the file as a unit: separate unrelated responsibilities before tuning individual rule thresholds."
              },
              "properties": {
                "pillar": "design",
                "defaultSeverity": "low",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "composite",
                  "opt-in"
                ],
                "thresholds": {
                  "minFindings": 3,
                  "minPillars": 2
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "docs.comment-rubric",
              "name": "Comment rubric",
              "shortDescription": {
                "text": "Comment rubric"
              },
              "fullDescription": {
                "text": "Flags files that opt into stricter maintainer comments for package summaries, functions, named types, and package-scope values."
              },
              "help": {
                "text": "Add maintainer-oriented package summaries and directly attached comments for the selected declaration kinds."
              },
              "properties": {
                "pillar": "documentation",
                "defaultSeverity": "low",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "comments",
                  "documentation",
                  "opt-in",
                  "rubric"
                ],
                "thresholds": {
                  "minPackageCommentLines": 2
                },
                "options": {
                  "excludePaths": [],
                  "ignoreTests": false,
                  "includePaths": [],
                  "requireConstComments": false,
                  "requireFunctionComments": false,
                  "requireInterfaceComments": false,
                  "requireNamedTypeComments": false,
                  "requirePackageSummary": false,
                  "requireStructComments": false,
                  "requireVarComments": false
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "docs.exported-symbol-comment",
              "name": "Exported symbol comment",
              "shortDescription": {
                "text": "Exported symbol comment"
              },
              "fullDescription": {
                "text": "Flags exported top-level Go declarations (functions, methods on exported types, types, vars, consts) that have no doc comment."
              },
              "help": {
                "text": "Add a Go-style doc comment that begins with the symbol name."
              },
              "properties": {
                "pillar": "documentation",
                "defaultSeverity": "low",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "opt-in"
                ],
                "options": {
                  "ignoreInternalPackages": true
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "docs.package-comment",
              "name": "Package comment",
              "shortDescription": {
                "text": "Package comment"
              },
              "fullDescription": {
                "text": "Flags Go packages that do not have a package-level comment in any file."
              },
              "help": {
                "text": "Add a package comment that explains the package responsibility."
              },
              "properties": {
                "pillar": "documentation",
                "defaultSeverity": "low",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.acronym-case",
              "name": "Acronym case",
              "shortDescription": {
                "text": "Acronym case"
              },
              "fullDescription": {
                "text": "Flags identifiers that spell configured Go initialisms with mixed casing."
              },
              "help": {
                "text": "Use all-caps initialisms in exported names and consistently cased initialisms in unexported names."
              },
              "properties": {
                "pillar": "naming",
                "defaultSeverity": "low",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "go-style",
                  "naming",
                  "opt-in"
                ],
                "options": {
                  "acronyms": [
                    "HTTP",
                    "URL",
                    "JSON",
                    "ID",
                    "XML",
                    "API",
                    "JWT",
                    "AWS",
                    "OAUTH",
                    "CSS",
                    "HTML",
                    "YAML",
                    "SARIF",
                    "ASCII",
                    "SQL",
                    "CLI",
                    "TCP",
                    "UDP",
                    "TLS",
                    "SSL",
                    "DNS",
                    "IP",
                    "GPU",
                    "CPU",
                    "OS"
                  ],
                  "allow": []
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.get-prefix",
              "name": "Get prefix",
              "shortDescription": {
                "text": "Get prefix"
              },
              "fullDescription": {
                "text": "Flags receiver accessor methods that use a Get prefix instead of a direct noun phrase."
              },
              "help": {
                "text": "Rename accessor-style methods from GetThing to Thing unless parameters make the lookup action explicit."
              },
              "properties": {
                "pillar": "naming",
                "defaultSeverity": "low",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "go-style",
                  "naming",
                  "opt-in"
                ],
                "options": {
                  "excludeNames": [],
                  "excludePaths": []
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.identifier-quality",
              "name": "Identifier quality",
              "shortDescription": {
                "text": "Identifier quality"
              },
              "fullDescription": {
                "text": "Flags local variables and constants whose names match a list of placeholder tokens that rarely survive a careful review."
              },
              "help": {
                "text": "Rename the identifier to something that names its role, or remove it if it is no longer needed."
              },
              "properties": {
                "pillar": "naming",
                "defaultSeverity": "low",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "naming",
                  "opt-in"
                ],
                "options": {
                  "placeholderNames": [
                    "foo",
                    "bar",
                    "baz",
                    "tmp",
                    "temp",
                    "obj",
                    "todo",
                    "thing",
                    "stuff"
                  ]
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.package-underscore",
              "name": "Package name contains underscore",
              "shortDescription": {
                "text": "Package name contains underscore"
              },
              "fullDescription": {
                "text": "Flags Go package names that use underscores instead of short lowercase words."
              },
              "help": {
                "text": "Rename the package to a short lowercase name without underscores."
              },
              "properties": {
                "pillar": "naming",
                "defaultSeverity": "low",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "go-style",
                  "opt-in"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.receiver-consistency",
              "name": "Receiver consistency",
              "shortDescription": {
                "text": "Receiver consistency"
              },
              "fullDescription": {
                "text": "Flags methods on the same type that use inconsistent receiver names or pointer/value forms."
              },
              "help": {
                "text": "Use one receiver name and one receiver pointer/value form per type, or explicitly allow a deliberate mixed form."
              },
              "properties": {
                "pillar": "naming",
                "defaultSeverity": "low",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "go-style",
                  "naming",
                  "opt-in"
                ],
                "options": {
                  "allowMixed": [],
                  "inspectGroup": "both"
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "security.shell-command",
              "name": "Shell command execution",
              "shortDescription": {
                "text": "Shell command execution"
              },
              "fullDescription": {
                "text": "Flags exec.Command calls that invoke a shell interpreter with command strings."
              },
              "help": {
                "text": "Call the target executable directly and pass arguments without shell interpretation."
              },
              "properties": {
                "pillar": "security",
                "secondaryPillars": [
                  "sensitive-data"
                ],
                "defaultSeverity": "medium",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "opt-in",
                  "security"
                ]
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            },
            {
              "id": "sensitive-data.aws-access-key",
              "name": "AWS access key id",
              "shortDescription": {
                "text": "AWS access key id"
              },
              "fullDescription": {
                "text": "Flags AWS access key identifiers (AKIA...) embedded in source or text files."
              },
              "help": {
                "text": "Rotate the key, then load credentials from the AWS SDK default provider chain rather than embedding them."
              },
              "properties": {
                "pillar": "sensitive-data",
                "defaultSeverity": "high",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "opt-in",
                  "secrets"
                ]
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "sensitive-data.connection-string",
              "name": "Connection string with embedded password",
              "shortDescription": {
                "text": "Connection string with embedded password"
              },
              "fullDescription": {
                "text": "Flags database/queue connection URLs that embed a username and password in the URI."
              },
              "help": {
                "text": "Pull the password from environment-specific runtime configuration; keep only the scheme and host in source-controlled strings."
              },
              "properties": {
                "pillar": "sensitive-data",
                "defaultSeverity": "high",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "opt-in",
                  "secrets"
                ]
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "sensitive-data.jwt-token",
              "name": "JWT token literal",
              "shortDescription": {
                "text": "JWT token literal"
              },
              "fullDescription": {
                "text": "Flags JWT-shaped literals (three base64url segments separated by dots) embedded in source or text files."
              },
              "help": {
                "text": "Move the token to a secret manager or runtime-only configuration; never check signed tokens into source control."
              },
              "properties": {
                "pillar": "sensitive-data",
                "defaultSeverity": "high",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "opt-in",
                  "secrets"
                ]
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "sensitive-data.private-key",
              "name": "Embedded private key",
              "shortDescription": {
                "text": "Embedded private key"
              },
              "fullDescription": {
                "text": "Flags PEM-encoded private keys embedded directly in source or text files."
              },
              "help": {
                "text": "Remove the key and load it from a secret manager or environment-specific runtime configuration."
              },
              "properties": {
                "pillar": "sensitive-data",
                "defaultSeverity": "critical",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "opt-in",
                  "secrets"
                ]
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "sensitive-data.secret-pattern",
              "name": "Secret-like literal",
              "shortDescription": {
                "text": "Secret-like literal"
              },
              "fullDescription": {
                "text": "Flags high-risk secret-like key/value assignments in Go and text/config files."
              },
              "help": {
                "text": "Move secrets to a secret manager or environment-specific runtime configuration."
              },
              "properties": {
                "pillar": "sensitive-data",
                "defaultSeverity": "high",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "size.file-length",
              "name": "File length",
              "shortDescription": {
                "text": "File length"
              },
              "fullDescription": {
                "text": "Flags Go files that exceed the default line-count threshold."
              },
              "help": {
                "text": "Split the file by responsibility or move focused behavior into smaller files."
              },
              "properties": {
                "pillar": "size",
                "defaultSeverity": "medium",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "thresholds": {
                  "maxLines": 400
                }
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            },
            {
              "id": "size.function-length",
              "name": "Function length",
              "shortDescription": {
                "text": "Function length"
              },
              "fullDescription": {
                "text": "Flags Go functions that exceed the default line-count threshold."
              },
              "help": {
                "text": "Extract cohesive helper functions or split independent branches."
              },
              "properties": {
                "pillar": "size",
                "defaultSeverity": "medium",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "thresholds": {
                  "maxLines": 4
                }
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            },
            {
              "id": "size.parameter-count",
              "name": "Parameter count",
              "shortDescription": {
                "text": "Parameter count"
              },
              "fullDescription": {
                "text": "Flags functions and methods whose parameter list exceeds the configured maximum, excluding the method receiver."
              },
              "help": {
                "text": "Group related parameters into a struct, accept an options type, or split the function."
              },
              "properties": {
                "pillar": "size",
                "defaultSeverity": "low",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": false,
                "tags": [
                  "opt-in"
                ],
                "thresholds": {
