{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "gruff-go",
          "semanticVersion": "0.2.0",
          "rules": [
            {
              "id": "complexity.cognitive",
              "name": "Cognitive complexity",
              "shortDescription": {
                "text": "Cognitive complexity"
              },
              "fullDescription": {
                "text": "Flags functions whose nested control flow and boolean decisions exceed the configured cognitive complexity threshold."
              },
              "help": {
                "text": "Flatten nested branches, return early, or extract cohesive helper functions."
              },
              "properties": {
                "pillar": "complexity",
                "defaultSeverity": "warning",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "metric"
                ],
                "thresholds": {
                  "maxComplexity": 35
                }
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            },
            {
              "id": "complexity.cyclomatic",
              "name": "Cyclomatic complexity",
              "shortDescription": {
                "text": "Cyclomatic complexity"
              },
              "fullDescription": {
                "text": "Flags Go functions whose branch count exceeds the default cyclomatic threshold."
              },
              "help": {
                "text": "Split independent decisions or move branches into named helpers."
              },
              "properties": {
                "pillar": "complexity",
                "defaultSeverity": "warning",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "thresholds": {
                  "maxComplexity": 2
                }
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            },
            {
              "id": "complexity.nesting-depth",
              "name": "Nesting depth",
              "shortDescription": {
                "text": "Nesting depth"
              },
              "fullDescription": {
                "text": "Flags functions whose maximum control-flow nesting depth exceeds the configured threshold. Function literals reset the count."
              },
              "help": {
                "text": "Extract nested branches into named helpers or return early on guard conditions."
              },
              "properties": {
                "pillar": "complexity",
                "defaultSeverity": "warning",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "thresholds": {
                  "maxDepth": 5
                }
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            },
            {
              "id": "complexity.npath",
              "name": "NPath complexity",
              "shortDescription": {
                "text": "NPath complexity"
              },
              "fullDescription": {
                "text": "Flags functions whose number of acyclic execution paths (NPath) exceeds the configured threshold. The modified NPath formula treats return/panic guards as exit points so idiomatic Go error chains grow linearly; genuine branch-combination blowups (nested switches, multi-way if/else without terminators) still flag."
              },
              "help": {
                "text": "Collapse boolean conditions, extract helper functions, or replace nested switches with table-driven dispatch so the path-combination count drops."
              },
              "properties": {
                "pillar": "complexity",
                "defaultSeverity": "warning",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "metric"
                ],
                "thresholds": {
                  "maxComplexity": 1024
                }
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            },
            {
              "id": "dead-code.empty-block",
              "name": "Empty control-flow block",
              "shortDescription": {
                "text": "Empty control-flow block"
              },
              "fullDescription": {
                "text": "Flags empty control-flow blocks that usually indicate unfinished or unnecessary code."
              },
              "help": {
                "text": "Remove the empty block or add the intended implementation."
              },
              "properties": {
                "pillar": "dead-code",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "dead-code.unreachable-code",
              "name": "Unreachable code",
              "shortDescription": {
                "text": "Unreachable code"
              },
              "fullDescription": {
                "text": "Flags statements that appear after return, panic, break, continue, or goto in the same block."
              },
              "help": {
                "text": "Remove the unreachable statement or move it before the terminating control-flow statement."
              },
              "properties": {
                "pillar": "dead-code",
                "defaultSeverity": "advisory",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "control-flow"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "dead-code.unused-private-function",
              "name": "Unused private function",
              "shortDescription": {
                "text": "Unused private function"
              },
              "fullDescription": {
                "text": "Flags package-private (lowercase-leading) top-level functions whose names are not referenced anywhere else in the same parsed package. Methods, init, main, and packages that import reflect are excluded so the rule stays precision-first."
              },
              "help": {
                "text": "Delete the function, export it if other packages need it, or confirm it is only used through reflection or build-tag-gated code paths and suppress the finding locally."
              },
              "properties": {
                "pillar": "dead-code",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "cross-file",
                  "dead-code"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "design.god-function",
              "name": "God function",
              "shortDescription": {
                "text": "God function"
              },
              "fullDescription": {
                "text": "Flags functions that already have both size and complexity findings, prioritising routines that need structural decomposition."
              },
              "help": {
                "text": "Split the function around cohesive responsibilities, then re-run the size and complexity rules to confirm both signals cleared."
              },
              "properties": {
                "pillar": "design",
                "secondaryPillars": [
                  "size",
                  "complexity"
                ],
                "defaultSeverity": "advisory",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "composite"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "design.hotspot-file",
              "name": "Hotspot file",
              "shortDescription": {
                "text": "Hotspot file"
              },
              "fullDescription": {
                "text": "Flags files with findings across multiple quality pillars, highlighting cross-cutting maintenance hotspots."
              },
              "help": {
                "text": "Triage the file as a unit: separate unrelated responsibilities before tuning individual rule thresholds."
              },
              "properties": {
                "pillar": "maintainability",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "composite"
                ],
                "thresholds": {
                  "minFindings": 3,
                  "minPillars": 2
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "docs.comment-rubric",
              "name": "Comment rubric",
              "shortDescription": {
                "text": "Comment rubric"
              },
              "fullDescription": {
                "text": "Flags files that opt into stricter maintainer comments for package summaries, functions, named types, and package-scope values. With minWordsBeyondSymbol set, the rule additionally requires the comment to carry that many tokens beyond the symbol's own name (rejects name-restatement boilerplate). On _test.go files the rule does not enforce requireConstComments or requireVarComments even when ignoreTests is false; function, type, and package-summary checks still apply."
              },
              "help": {
                "text": "Add maintainer-oriented package summaries and directly attached comments for the selected declaration kinds. When minWordsBeyondSymbol is set, the comment must add at least that many tokens beyond the symbol's own identifier tokens; replace name-restatement summaries with substantive context."
              },
              "properties": {
                "pillar": "documentation",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "comments",
                  "documentation",
                  "rubric"
                ],
                "thresholds": {
                  "minPackageCommentLines": 1
                },
                "options": {
                  "excludePaths": [],
                  "ignoreTests": false,
                  "includePaths": [],
                  "minWordsBeyondSymbol": 0,
                  "requireConstComments": false,
                  "requireFunctionComments": false,
                  "requireInterfaceComments": false,
                  "requireNamedTypeComments": false,
                  "requirePackageSummary": false,
                  "requireStructComments": false,
                  "requireVarComments": false
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "docs.config-field-comment",
              "name": "Config field comment",
              "shortDescription": {
                "text": "Config field comment"
              },
              "fullDescription": {
                "text": "Flags exported fields on struct types in configured includePaths that have no useful doc comment. Embedded and unexported fields are out of scope."
              },
              "help": {
                "text": "Add a doc comment to every exported field of structs declared in the configured includePaths."
              },
              "properties": {
                "pillar": "documentation",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "comments",
                  "documentation",
                  "struct-fields"
                ],
                "options": {
                  "excludePaths": [],
                  "includePaths": []
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "docs.exported-symbol-comment",
              "name": "Exported symbol comment",
              "shortDescription": {
                "text": "Exported symbol comment"
              },
              "fullDescription": {
                "text": "Flags exported top-level Go declarations (functions, methods on exported types, types, vars, consts) that have no doc comment."
              },
              "help": {
                "text": "Add a Go-style doc comment that begins with the symbol name."
              },
              "properties": {
                "pillar": "documentation",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "options": {
                  "ignoreInternalPackages": true
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "docs.package-comment",
              "name": "Package comment",
              "shortDescription": {
                "text": "Package comment"
              },
              "fullDescription": {
                "text": "Flags Go packages that do not have a package-level comment in any file."
              },
              "help": {
                "text": "Add a package comment that explains the package responsibility."
              },
              "properties": {
                "pillar": "documentation",
                "defaultSeverity": "advisory",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "docs.suppression-without-rationale",
              "name": "Suppression without rationale",
              "shortDescription": {
                "text": "Suppression without rationale"
              },
              "fullDescription": {
                "text": "Flags nolint and nosec suppression comments that do not explain why the suppression is intentional."
              },
              "help": {
                "text": "Add a short reason after the suppression, such as `-- false positive because ...` or `// tracked in ISSUE-123`."
              },
              "properties": {
                "pillar": "documentation",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "comments",
                  "documentation"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "maintainability.context-todo-production",
              "name": "Context TODO in production",
              "shortDescription": {
                "text": "Context TODO in production"
              },
              "fullDescription": {
                "text": "Flags context.TODO calls in production files where cancellation ownership should be explicit."
              },
              "help": {
                "text": "Accept a caller-provided context or use a documented bootstrap context where cancellation is intentionally unavailable."
              },
              "properties": {
                "pillar": "maintainability",
                "defaultSeverity": "advisory",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "context"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "maintainability.defer-in-loop",
              "name": "Defer in loop",
              "shortDescription": {
                "text": "Defer in loop"
              },
              "fullDescription": {
                "text": "Flags defer statements directly inside loops, where cleanup is delayed until the enclosing function returns."
              },
              "help": {
                "text": "Move the loop body into a helper function or close the resource explicitly before the next iteration."
              },
              "properties": {
                "pillar": "maintainability",
                "defaultSeverity": "advisory",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "lifecycle"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "maintainability.ignored-error",
              "name": "Ignored error",
              "shortDescription": {
                "text": "Ignored error"
              },
              "fullDescription": {
                "text": "Flags error-looking values that are assigned directly to the blank identifier."
              },
              "help": {
                "text": "Handle the error, return it to the caller, or document why ignoring it is safe."
              },
              "properties": {
                "pillar": "maintainability",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "errors"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "maintainability.log-fatal-library",
              "name": "Library fatal exit",
              "shortDescription": {
                "text": "Library fatal exit"
              },
              "fullDescription": {
                "text": "Flags log.Fatal and os.Exit calls outside command entrypoints and tests."
              },
              "help": {
                "text": "Return an error to the caller and let command/bootstrap code decide whether to terminate the process."
              },
              "properties": {
                "pillar": "maintainability",
                "defaultSeverity": "advisory",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "errors",
                  "lifecycle"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "maintainability.loop-variable-address",
              "name": "Range variable address escapes",
              "shortDescription": {
                "text": "Range variable address escapes"
              },
              "fullDescription": {
                "text": "Flags storing, returning, or appending the address of a range variable copy."
              },
              "help": {
                "text": "Take the address of the indexed collection element, or copy the value into a deliberately scoped variable before storing its address."
              },
              "properties": {
                "pillar": "maintainability",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "loops"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "maintainability.production-panic",
              "name": "Production panic",
              "shortDescription": {
                "text": "Production panic"
              },
              "fullDescription": {
                "text": "Flags direct literal panic calls in non-test, non-main production code."
              },
              "help": {
                "text": "Return an error or fail during command/bootstrap setup instead of panicking from reusable production code."
              },
              "properties": {
                "pillar": "maintainability",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "errors"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "modernisation.ioutil-deprecated",
              "name": "Deprecated ioutil API",
              "shortDescription": {
                "text": "Deprecated ioutil API"
              },
              "fullDescription": {
                "text": "Flags calls to io/ioutil APIs that have direct io or os replacements in modern Go."
              },
              "help": {
                "text": "Replace io/ioutil calls with the matching io or os package API."
              },
              "properties": {
                "pillar": "modernisation",
                "defaultSeverity": "advisory",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "go-style"
                ],
                "options": {
                  "minimumGoVersion": "1.16"
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.acronym-case",
              "name": "Acronym case",
              "shortDescription": {
                "text": "Acronym case"
              },
              "fullDescription": {
                "text": "Flags identifiers that spell configured Go initialisms with mixed casing."
              },
              "help": {
                "text": "Use all-caps initialisms in exported names and consistently cased initialisms in unexported names."
              },
              "properties": {
                "pillar": "naming",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "go-style",
                  "naming"
                ],
                "options": {
                  "acronyms": [
                    "HTTP",
                    "URL",
                    "JSON",
                    "ID",
                    "XML",
                    "API",
                    "JWT",
                    "AWS",
                    "OAUTH",
                    "CSS",
                    "HTML",
                    "YAML",
                    "SARIF",
                    "ASCII",
                    "SQL",
                    "CLI",
                    "TCP",
                    "UDP",
                    "TLS",
                    "SSL",
                    "DNS",
                    "IP",
                    "GPU",
                    "CPU",
                    "OS"
                  ],
                  "allow": []
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.contextual-generic",
              "name": "Contextual generic name",
              "shortDescription": {
                "text": "Contextual generic name"
              },
              "fullDescription": {
                "text": "Flags generic range variables and accumulator names only when surrounding context is large enough that the name loses meaning."
              },
              "help": {
                "text": "Rename long-loop values and long-function accumulators to describe the data role they carry."
              },
              "properties": {
                "pillar": "naming",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "naming"
                ],
                "thresholds": {
                  "minBodyLines": 15,
                  "minFunctionLines": 50
                },
                "options": {
                  "accumulatorNames": [
                    "out",
                    "result"
                  ],
                  "genericNames": [
                    "item",
                    "value",
                    "entry",
                    "elem",
                    "v"
                  ],
                  "requireMultiple": true
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.get-prefix",
              "name": "Get prefix",
              "shortDescription": {
                "text": "Get prefix"
              },
              "fullDescription": {
                "text": "Flags receiver accessor methods that use a Get prefix instead of a direct noun phrase."
              },
              "help": {
                "text": "Rename accessor-style methods from GetThing to Thing unless parameters make the lookup action explicit."
              },
              "properties": {
                "pillar": "modernisation",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "go-style",
                  "naming"
                ],
                "options": {
                  "excludeNames": [],
                  "excludePaths": []
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.identifier-quality",
              "name": "Identifier quality",
              "shortDescription": {
                "text": "Identifier quality"
              },
              "fullDescription": {
                "text": "Flags local variables and constants whose names match a list of placeholder tokens that rarely survive a careful review."
              },
              "help": {
                "text": "Rename the identifier to something that names its role, or remove it if it is no longer needed."
              },
              "properties": {
                "pillar": "naming",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "naming"
                ],
                "options": {
                  "placeholderNames": [
                    "foo",
                    "bar",
                    "baz",
                    "tmp",
                    "temp",
                    "obj",
                    "todo",
                    "thing",
                    "stuff"
                  ]
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.misspelling",
              "name": "Misspelled identifier or comment",
              "shortDescription": {
                "text": "Misspelled identifier or comment"
              },
              "fullDescription": {
                "text": "Flags identifiers, doc comments, and struct tags containing common programming misspellings."
              },
              "help": {
                "text": "Replace the misspelled token with the suggested correction. Use the `ignore` option for project-specific terms that look like misspellings but are intentional (proper nouns, vendor-specific terms)."
              },
              "properties": {
                "pillar": "naming",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "naming"
                ],
                "options": {
                  "extra": {},
                  "ignore": []
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.negated-boolean",
              "name": "Negated boolean",
              "shortDescription": {
                "text": "Negated boolean"
              },
              "fullDescription": {
                "text": "Flags boolean identifiers whose names start with negation prefixes (No, Not, Disable, etc.), which force double-negation at call sites."
              },
              "help": {
                "text": "Rename to the positive form (e.g. Skip… instead of No…) so call sites read without double negation."
              },
              "properties": {
                "pillar": "naming",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "go-style",
                  "naming"
                ],
                "options": {
                  "allowList": [
                    "NoOp",
                    "Notify",
                    "Notice",
                    "Now",
                    "NoCopy",
                    "Notation",
                    "Notebook"
                  ],
                  "prefixes": [
                    "No",
                    "Not",
                    "Disable",
                    "Disallow",
                    "Without",
                    "Suppress"
                  ],
                  "scope": "exported"
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.package-stutter",
              "name": "Package stutter",
              "shortDescription": {
                "text": "Package stutter"
              },
              "fullDescription": {
                "text": "Flags exported identifiers whose lowercase form starts with their own package name (config.ConfigOptions, rule.RuleRegistry)."
              },
              "help": {
                "text": "Rename the identifier to remove the package-name prefix so call sites read `config.Options` instead of `config.ConfigOptions`. Use `allowStutter` for single-noun stutter the community accepts (Config, Finding)."
              },
              "properties": {
                "pillar": "naming",
                "defaultSeverity": "advisory",
                "confidence": "medium",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "go-style",
                  "naming"
                ],
                "options": {
                  "allowStutter": [
                    "Config",
                    "Finding"
                  ]
                }
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.package-underscore",
              "name": "Package name contains underscore",
              "shortDescription": {
                "text": "Package name contains underscore"
              },
              "fullDescription": {
                "text": "Flags Go package names that use underscores instead of short lowercase words."
              },
              "help": {
                "text": "Rename the package to a short lowercase name without underscores."
              },
              "properties": {
                "pillar": "naming",
                "defaultSeverity": "advisory",
                "confidence": "high",
                "capability": "parser",
                "defaultEnabled": true,
                "tags": [
                  "go-style"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "naming.receiver-consistency",
              "name": "Receiver consistency",
              "shortDescription": {
                "text": "Receiver consistency"
              },
              "fullDescription": {
                "text": "Flags methods on the same type that use inconsistent receiver names or pointer/value forms."
              },
