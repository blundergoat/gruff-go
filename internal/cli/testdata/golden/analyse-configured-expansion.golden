      "advisory": 4,
      "error": 0,
      "warning": 1
    },
    "countsByPillar": {
      "complexity": 1,
      "design": 1,
      "documentation": 1,
      "maintainability": 1,
      "size": 1
    },
    "exitCode": 1,
    "parserMode": "parser-only",
    "typeLoadingEnabled": false
  },
  "baseline": {
    "applied": false,
    "entries": 0,
    "suppressedFindings": 0,
    "staleEntries": 0
  },
  "diff": {
    "enabled": false,
    "changedFiles": [],
    "filteredFindings": 0
  },
  "displayFilter": {
    "applied": false,
    "includeRules": [],
    "excludeRules": [],
    "includePillars": [],
    "excludePillars": [],
    "hiddenFindings": 0
  },
  "score": {
    "composite": 96,
    "grade": "A",
    "pillars": {
      "complexity": 92,
      "documentation": 99,
      "size": 99
    },
    "pillarDetails": [
      {
        "pillar": "complexity",
        "score": 92,
        "grade": "A",
        "findings": 1,
        "advisory": 0,
        "warning": 1,
        "error": 0,
        "penalty": 8
      },
      {
        "pillar": "documentation",
        "score": 99,
        "grade": "A",
        "findings": 1,
        "advisory": 1,
        "warning": 0,
        "error": 0,
        "penalty": 1
      },
      {
        "pillar": "size",
        "score": 99,
        "grade": "A",
        "findings": 1,
        "advisory": 1,
        "warning": 0,
        "error": 0,
        "penalty": 1
      }
    ],
    "coverage": {
      "contributingPillars": [
        "complexity",
        "documentation",
        "size"
      ]
    },
    "topOffenders": [
      {
        "file": "expansion.go",
