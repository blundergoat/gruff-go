{
  "schemaVersion": "gruff-go.analysis.v0.2",
  "tool": {
    "name": "gruff-go",
    "version": "0.1.2"
  },
  "run": {
    "workingDirectory": "<WORKDIR>",
    "inputs": [
      "expansion.go"
    ],
    "format": "summary-json",
    "failOn": "advisory"
