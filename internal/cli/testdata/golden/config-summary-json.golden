{
  "schemaVersion": "gruff-go.analysis.v0.2",
  "tool": {
    "name": "gruff-go",
    "version": "0.1.1"
  },
  "run": {
    "workingDirectory": "<WORKDIR>",
    "inputs": [
      "complex.go"
    ],
    "format": "summary-json",
    "failOn": "advisory"
  },
  "summary": {
    "filesScanned": 1,
    "filesSkipped": 0,
    "diagnosticsCount": 0,
    "findingsCount": 0,
    "countsBySeverity": {
      "advisory": 0,
      "error": 0,
      "warning": 0
    },
    "countsByPillar": {},
    "exitCode": 0,
    "parserMode": "parser-only",
    "typeLoadingEnabled": false
  },
  "baseline": {
    "applied": false,
    "entries": 0,
    "suppressedFindings": 0,
    "staleEntries": 0
  },
  "diff": {
    "enabled": false,
    "changedFiles": [],
    "filteredFindings": 0
  },
  "displayFilter": {
    "applied": false,
    "includeRules": [],
    "excludeRules": [],
    "includePillars": [],
    "excludePillars": [],
    "hiddenFindings": 0
  },
  "score": {
    "composite": 100,
    "grade": "A",
    "pillars": {},
    "pillarDetails": [],
    "coverage": {
      "contributingPillars": [],
      "caveat": "No score-impacting findings; the score reflects configured parser rules and thresholds, not exhaustive semantic proof."
    },
    "topOffenders": [],
    "complexityDistribution": {
      "1-5": 0,
      "11-15": 0,
      "16-20": 0,
      "21+": 0,
      "6-10": 0
    },
    "complexityDistributionScope": "finding-only"
  },
  "diagnostics": []
}
