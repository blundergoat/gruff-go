{
  "schemaVersion": "gruff-go.analysis.v0.2",
  "tool": {
    "name": "gruff-go",
    "version": "0.2.0"
  },
  "run": {
    "workingDirectory": "<WORKDIR>",
    "inputs": [
      "complex.go"
    ],
    "format": "summary-json",
    "failOn": "advisory"
  },
  "summary": {
    "filesScanned": 1,
    "filesSkipped": 0,
    "diagnosticsCount": 0,
    "findingsCount": 1,
    "countsBySeverity": {
      "advisory": 0,
      "error": 0,
      "warning": 1
    },
    "countsByPillar": {
      "complexity": 1
    },
    "exitCode": 1,
    "parserMode": "parser-only",
    "typeLoadingEnabled": false
  },
  "baseline": {
    "applied": false,
    "entries": 0,
    "suppressedFindings": 0,
    "staleEntries": 0
  },
  "diff": {
    "enabled": true,
    "base": "HEAD",
    "changedFiles": [
      "complex.go"
    ],
    "filteredFindings": 0,
    "caveat": "diff mode is changed-line scoped and is not full-project proof for project-level rules"
  },
  "displayFilter": {
    "applied": false,
    "includeRules": [],
    "excludeRules": [],
    "includePillars": [],
    "excludePillars": [],
    "hiddenFindings": 0
  },
  "score": {
    "composite": 92,
    "grade": "A",
    "pillars": {
      "complexity": 92
    },
    "pillarDetails": [
      {
        "pillar": "complexity",
        "score": 92,
        "grade": "A",
        "findings": 1,
        "advisory": 0,
        "warning": 1,
        "error": 0,
        "penalty": 8
      }
    ],
    "coverage": {
      "contributingPillars": [
        "complexity"
      ],
      "caveat": "Composite grade is driven by 1 score-impacting pillar; clean pillars mean no above-threshold findings from configured rules, not broad risk coverage."
    },
    "topOffenders": [
      {
        "file": "complex.go",
        "penalty": 8,
        "findings": 1,
        "grade": "A",
        "maxCyclomatic": 22
      }
    ],
    "complexityDistribution": {
      "1-5": 0,
      "11-15": 0,
      "16-20": 0,
      "21+": 1,
      "6-10": 0
    },
    "complexityDistributionScope": "finding-only"
  },
  "diagnostics": []
}
