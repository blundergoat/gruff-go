# Auto-detect text files and normalize line endings to LF.
* text=auto eol=lf

# Shell scripts must always be LF. CRLF breaks shebangs on Linux/macOS.
*.sh text eol=lf

# Go files.
*.go text eol=lf

# Common source and config files.
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
Makefile text eol=lf

# Binary files.
*.gif binary
*.ico binary
*.jpeg binary
*.jpg binary
*.pdf binary
*.png binary
*.ttf binary
*.woff binary
*.woff2 binary
